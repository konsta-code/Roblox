{
  "name": "CTFGame",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Modules": {
        "$className": "Folder",
        "CTFSignals": { "$path": "CTFSignals.lua" },
        "FlagConstants": { "$path": "FlagConstants.lua" },
        "MatchConstants": { "$path": "MatchConstants.lua" },
        "MatchSignals": { "$path": "MatchSignals.lua" },
        "MovementConstants": { "$path": "MovementConstants.lua" },
        "PlayerHudState": { "$path": "PlayerHudState.lua" },
        "SpawnConstants": { "$path": "SpawnConstants.lua" },
        "WeaponConstants": { "$path": "WeaponConstants.lua" },
        "ChaingunConstants": { "$path": "ChaingunConstants.lua" }
      },
      "FireWeapon": { "$className": "RemoteEvent" },
      "FireChaingun": { "$className": "RemoteEvent" },
      "CTFScoreUpdate": { "$className": "RemoteEvent" },
      "FlagCarryStatus": { "$className": "RemoteEvent" },
      "MatchStateChanged": { "$className": "RemoteEvent" }
    },

    "ServerScriptService": {
