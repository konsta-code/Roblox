      "StarterPlayerScripts": {
        "SkiController": { "$path": "SkiController.client.lua" },
        "HudController": { "$path": "HudController.client.lua" },
        "Chaingun": { "$path": "Chaingun.client.lua" },
        "ProjectileWeapon": { "$path": "ProjectileWeapon.client.lua" }
      }
    },

    "Teams": {
      "Red": { "$className": "Team" },
      "Blue": { "$className": "Team" }
    }
  }
}
